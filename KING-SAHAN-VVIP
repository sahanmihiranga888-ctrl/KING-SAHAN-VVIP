<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KING SHORT - Signal Generator</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #121214;
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background-color: #1e1e24;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 400px;
            box-sizing: border-box;
            border: 1px solid #ff007f;
        }
        h2 {
            text-align: center;
            color: #ff007f;
            margin-bottom: 25px;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 22px;
        }
        .input-group {
            margin-bottom: 25px;
        }
        label {
            display: block;
            margin-bottom: 12px;
            color: #bbb;
            font-size: 14px;
            text-align: center;
            font-weight: bold;
            letter-spacing: 1px;
        }
        input {
            width: 100%;
            padding: 14px;
            border-radius: 8px;
            border: 1px solid #444;
            background-color: #2a2a35;
            color: #fff;
            font-size: 18px;
            box-sizing: border-box;
            text-align: center;
            letter-spacing: 1px;
        }
        input:focus {
            border-color: #ff007f;
            outline: none;
            box-shadow: 0 0 8px rgba(255, 0, 127, 0.4);
        }
        button {
            width: 100%;
            padding: 14px;
            background-color: #ff007f;
            border: none;
            border-radius: 8px;
            color: white;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }
        button:hover {
            background-color: #e0006c;
        }
        .secondary-btn {
            background-color: #3a3a45;
            color: #ffffff;
            border: 1px solid #555;
        }
        .secondary-btn:hover {
            background-color: #4a4a55;
        }
        .result-box {
            padding: 20px;
            background-color: #2a2a35;
            border-radius: 8px;
            border: 1px solid #00ff88;
            margin-bottom: 25px;
        }
        .result-title {
            font-weight: bold;
            color: #00ff88;
            text-align: center;
            margin-bottom: 15px;
            font-size: 16px;
            letter-spacing: 1px;
        }
        .signal-time {
            font-size: 26px;
            font-weight: bold;
            letter-spacing: 1px;
            color: #ffffff;
            text-align: center;
        }
        .error-msg {
            color: #ff3333;
            text-align: center;
            margin-top: 10px;
            font-size: 14px;
            display: none;
        }
        /* Step පාලනය කරන සෙටින්ග්ස් */
        .step-panel {
            display: none; /* මුලින්ම හැම එකක්ම හංගනවා */
        }
        #stepPassword {
            display: block; /* මුලින්ම පෙන්වන්නේ PW ස්ක්‍රීන් එක විතරයි */
        }
    </style>
</head>
<body>

<!-- STEP 1: PASSWORD SCREEN -->
<div class="container step-panel" id="stepPassword">
    <h2>VIP ACCESS LOCK</h2>
    <div class="input-group">
        <label for="pwInput">ENTER VIP PASSWORD</label>
        <input type="password" id="pwInput" placeholder="••••••••">
        <div class="error-msg" id="errorMsg">වැරදි මුරපදයක්! නැවත උත්සාහ කරන්න.</div>
    </div>
    <button onclick="checkPassword()">UNLOCK APP</button>
</div>

<!-- STEP 2: TIME INPUT SCREEN -->
<div class="container step-panel" id="stepTime">
    <h2>STEP 1: TIME</h2>
    <div class="input-group">
        <label for="timeInput">INPUT LAST MATCH TIME<br>(HH:MM:SS)</label>
        <input type="text" id="timeInput" placeholder="08:52:37">
    </div>
    <button onclick="goToOdds()">NEXT STEP ➡️</button>
</div>

<!-- STEP 3: ODDS INPUT SCREEN -->
<div class="container step-panel" id="stepOdds">
    <h2>STEP 2: ODDS</h2>
    <div class="input-group">
        <label for="oddsInput">INPUT HIGH ODDS MULTIPLIER<br>(e.g., 23.12)</label>
        <input type="text" id="oddsInput" placeholder="23.12">
    </div>
    <button onclick="generateSignal()">GENERATE SIGNAL 🎯</button>
    <button class="secondary-btn" onclick="backToTime()">⬅️ BACK</button>
</div>

<!-- STEP 4: RESULT SCREEN -->
<div class="container step-panel" id="stepResult">
    <h2>🎯 KING SHORT SIGNALS</h2>
    <div class="result-box">
        <div class="result-title">PREDICTED LUCKY MINUTES</div>
        <div class="signal-time" id="signalOutput">00:00 | 00:00</div>
    </div>
    <button onclick="restartApp()">🔄 START AGAIN</button>
</div>

<script>
// ඔයාගේ රහස් Passwords 5
const ALLOWED_PASSWORDS = ["KING77", "VIP99", "SHORT01", "BONY7", "FUN26"]; 

// ස්ක්‍රීන් මාරු කරන සරල Function එක
function switchStep(nextStepId) {
    // හැම පැනල් එකක්ම හංගනවා
    document.querySelectorAll('.step-panel').forEach(panel => {
        panel.style.display = 'none';
    });
    // අවශ්‍ය එක විතරක් පෙන්වනවා
    document.getElementById(nextStepId).style.display = 'block';
}

// Password Check කිරීම
function checkPassword() {
    let enteredPw = document.getElementById('pwInput').value.trim();
    let errorMsg = document.getElementById('errorMsg');
    
    if(ALLOWED_PASSWORDS.includes(enteredPw)) {
        switchStep('stepTime'); // හරිනම් Time ස්ක්‍රීන් එකට යනවා
    } else {
        errorMsg.style.display = 'block';
        document.getElementById('pwInput').value = '';
    }
}

// Time එකෙන් Odds එකට යාම
function goToOdds() {
    let timeStr = document.getElementById('timeInput').value.trim();
    if(!timeStr) {
        alert("කරුණාකර Time එක ඇතුළත් කරන්න!");
        return;
    }
    let timeParts = timeStr.split(':');
    if(timeParts.length < 2) {
        alert("Time Format එක වැරදියි! HH:MM:SS විදිහට දාන්න (උදා: 08:52:37)");
        return;
    }
    switchStep('stepOdds'); // Odds ස්ක්‍රීන් එකට යනවා
}

// Odds එකේ සිට ආපසු Time එකට යාම (Back Button)
function backToTime() {
    switchStep('stepTime');
}

// අවසාන පියවර: සිග්නල් එක හැදීම සහ පෙන්වීම
function generateSignal() {
    let timeStr = document.getElementById('timeInput').value.trim();
    let oddsStr = document.getElementById('oddsInput').value.trim();
    
    if(!oddsStr) {
        alert("කරුණාකර High Odds එක ඇතුළත් කරන්න!");
        return;
    }

    let timeParts = timeStr.split(':');
    let hours = parseInt(timeParts[0]);
    let minutes = parseInt(timeParts[1]);
    
    // ඊළඟ මිනිත්තුවට වටයෑම
    minutes = minutes + 1;
    if(minutes >= 60) {
        minutes = 0;
        hours = (hours + 1) % 24;
    }

    // Odds වල ඉලක්කම් එකතු කිරීම
    let cleanOdds = oddsStr.replace(/[^0-9]/g, ''); 
    let sumOfDigits = 0;
    for (let i = 0; i < cleanOdds.length; i++) {
        sumOfDigits += parseInt(cleanOdds[i]);
    }

    minutes = minutes + sumOfDigits;
    
    while (minutes >= 60) {
        minutes = minutes - 60;
        hours = (hours + 1) % 24;
    }

    let s1Hours = hours.toString().padStart(2, '0');
    let s1Minutes = minutes.toString().padStart(2, '0');
    let signal1 = `${s1Hours}:${s1Minutes}`;

    let nextMinutes = minutes + 1;
    let s2Hours = hours;
    if (nextMinutes >= 60) {
        nextMinutes = 0;
        s2Hours = (hours + 1) % 24;
    }
    s2Hours = s2Hours.toString().padStart(2, '0');
    nextMinutes = nextMinutes.toString().padStart(2, '0');
    let signal2 = `${s2Hours}:${nextMinutes}`;

    // Result එක දාලා Result ස්ක්‍රීන් එක පෙන්වනවා
    document.getElementById('signalOutput').innerHTML = `${signal1} &nbsp;|&nbsp; ${signal2}`;
    switchStep('stepResult');
}

// ආයෙත් මුල ඉඳන් පටන් ගැනීම (Start Again)
function restartApp() {
    // Inputs හිස් කරනවා
    document.getElementById('timeInput').value = '';
    document.getElementById('oddsInput').value = '';
    // කෙලින්ම Time ස්ක්‍රීන් එකට යනවා (ආයෙ PW ගහන්න ඕන නෑ)
    switchStep('stepTime');
}
</script>

</body>
</html>
